[gd_scene format=3 uid="uid://b5n2r3tp26t5w"]

[sub_resource type="GDScript" id="GDScript_beaaf"]
script/source = "extends VBoxContainer

var config = ConfigFile.new()

var keybind_controls: Array[HBoxContainer]


func save_keybind(save_category: String, save_name: String, event: InputEvent) -> void:
	config.set_value(save_category, save_name, event)
	config.save(\"user://keybinds.ini\")


func clear() -> void:
	keybind_controls.clear()
	for child in $ScrollContainer/VBoxContainer.get_children():
		$ScrollContainer/VBoxContainer.remove_child(child)
		child.queue_free()


func populate() -> void:
	config.load(\"user://keybinds.ini\")
	var category = ''
	var new_vbox: VBoxContainer
	for action in InputMap.get_actions():
		
		# Ignore built-in input actions
		if action.begins_with('ui_'):
			continue
		
		# Grab input actions of the form \"category_action_name\"
		if action.split('_')[0] != category:
			category = action.split('_')[0]
			
			# Create dropdown for the category
			var new_accordion = FoldableContainer.new()
			new_accordion.title = category.capitalize()
			new_accordion.title_alignment = HORIZONTAL_ALIGNMENT_CENTER
			$ScrollContainer/VBoxContainer.add_child(new_accordion)
			new_vbox = VBoxContainer.new()
			new_accordion.add_child(new_vbox)
		
		# Create keybind UI object
		var key = action.trim_prefix(category + '_')
		var new_keybind_control = preload(\"res://source/ui/menu/Keybind.tscn\").instantiate()
		keybind_controls.append(new_keybind_control)
		new_keybind_control.action_category = category
		new_keybind_control.action_name = key
		
		# Get event from config if it exists, otherwise use the default in ProjectSettings
		if config.has_section_key(category, key):
			var event = config.get_value(category, key)
			InputMap.action_erase_events(action)
			InputMap.action_add_event(action, event)
			new_keybind_control.event = event
		else:
			new_keybind_control.event = InputMap.action_get_events(action)[0]
		new_vbox.add_child(new_keybind_control)


func _ready() -> void:
	clear()
	populate()


func _on_back_pressed():
	for kc in keybind_controls:
		kc.set_process_input(false)


func _on_save_pressed():
	for kc in keybind_controls:
		save_keybind(kc.action_category, kc.action_name, kc.event)
		var full_name = kc.action_category + '_' + kc.action_name
		if !InputMap.has_action(full_name):
			continue
		InputMap.action_erase_events(full_name)
		InputMap.action_add_event(full_name, kc.event)


func _on_reset_pressed():
	clear()
	populate()
"

