[gd_scene format=3 uid="uid://c7appb3m7x6pr"]

[ext_resource type="Texture2D" uid="uid://ctplmliaih1xw" path="res://assets/art/icons/x_sm.png" id="1_dkyxp"]

[sub_resource type="GDScript" id="GDScript_807by"]
script/source = "extends HBoxContainer


var action_category: String
var action_name: String
var event: InputEvent


func reset() -> void:
	set_process_input(false)
	$Button.text = event.as_text()


func _ready() -> void:
	set_process_input(false)
	$Label.text = action_name.capitalize()
	$Button.text = event.as_text()


func _on_button_pressed() -> void:
	$Button.text = 'press key...'
	set_process_input(true)


func _input(e) -> void:
	get_viewport().set_input_as_handled()
	if e is InputEventKey:
		if e.is_pressed():
			event = e
			$Button.text = event.as_text()
		elif e.is_released():
			reset()
	elif e is InputEventMouseButton:
		if e.is_pressed():
			event = e
			$Button.text = event.as_text()
			reset()


func _on_clear_button_pressed():
	event = null
	$Button.text = ''
"

