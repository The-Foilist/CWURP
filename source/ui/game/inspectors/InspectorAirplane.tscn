[gd_scene format=3 uid="uid://bfn51hnw4st5"]

[sub_resource type="GDScript" id="GDScript_lnjdq"]
script/source = "extends VBoxContainer

var linked_mover: MoverAirplane
var taxi_mover: MoverTaxi


func _ready() -> void:
	taxi_mover = linked_mover.taxi_mover


func _process(_delta) -> void:
	if !linked_mover:
		get_parent().remove_child(self)
		queue_free()
		return
	var pos_data: Dictionary
	if linked_mover.active:
		pos_data = linked_mover.pos_data
		$GridContainer/LatitudeReadout.text = \"%.2f \" % pos_data['coords'].x
		$GridContainer/LongitudeReadout.text = \"%.2f \" % pos_data['coords'].y
		$GridContainer/HeadingReadout.text = \"%03.1f °\" % fposmod(linked_mover.unit.global_rotation_degrees, 360)
		$GridContainer/MSLReadout.text = \"%.0f \" % (linked_mover.unit.height / Global.DISTANCE_CONVERSION[PlayerSettings.altitude_units]) + PlayerSettings.altitude_units
		$GridContainer/AGLReadout.text = \"%.0f \" % ((linked_mover.unit.height - max(pos_data['height'], 0)) / Global.DISTANCE_CONVERSION[PlayerSettings.altitude_units]) + PlayerSettings.altitude_units
		$GridContainer/TASReadout.text = \"%.1f \" % (linked_mover.air_speed / Global.SPEED_CONVERSION[PlayerSettings.aircraft_speed_units]) + PlayerSettings.aircraft_speed_units
		$GridContainer/GSReadout.text = \"%.1f \" %  (linked_mover.unit.speed / Global.SPEED_CONVERSION[PlayerSettings.aircraft_speed_units]) + PlayerSettings.aircraft_speed_units
	elif taxi_mover.active:
		pos_data = taxi_mover.pos_data
		$GridContainer/LatitudeReadout.text = \"%.2f \" % pos_data['coords'].x
		$GridContainer/LongitudeReadout.text = \"%.2f \" % pos_data['coords'].y
		$GridContainer/HeadingReadout.text = \"%03.1f °\" % fposmod(taxi_mover.unit.global_rotation_degrees, 360)
		$GridContainer/MSLReadout.text = \"%.0f \" % (taxi_mover.unit.height / Global.DISTANCE_CONVERSION[PlayerSettings.altitude_units]) + PlayerSettings.altitude_units
		$GridContainer/AGLReadout.text = \"0 \" + PlayerSettings.altitude_units
		$GridContainer/TASReadout.text = \"%.1f \" % (taxi_mover.air_speed / Global.SPEED_CONVERSION[PlayerSettings.aircraft_speed_units]) + PlayerSettings.aircraft_speed_units
		$GridContainer/GSReadout.text = \"%.1f \" %  (taxi_mover.ground_speed / Global.SPEED_CONVERSION[PlayerSettings.aircraft_speed_units]) + PlayerSettings.aircraft_speed_units
"

