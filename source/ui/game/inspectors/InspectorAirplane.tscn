[gd_scene format=3 uid="uid://bfn51hnw4st5"]

[sub_resource type="GDScript" id="GDScript_lnjdq"]
script/source = "extends Inspector

var taxi_mover: MoverTaxi
var engine: AircraftEngine


func _ready() -> void:
	taxi_mover = linked_object.taxi_mover
	engine = linked_object.engine


func _process(delta) -> void:
	super(delta)
	if not(linked_object is MoverAirplane):
		get_parent().remove_child(self)
		queue_free()
		return
	var pos_data: Dictionary
	if linked_object.active:
		$Nav/HeadingReadout.text = \"%03.0f °\" % fposmod(round(linked_object.unit.global_rotation_degrees), 360)
		$Nav/TrackReadout.text = \"%03.0f °\" % fposmod(linked_object.track_heading, 360)
		$Nav/PitchReadout.text = \"%.1f °\" % rad_to_deg(linked_object.pitch_angle)
		$Nav/TASReadout.text = \"%.1f \" % (linked_object.air_speed / Global.SPEED_CONVERSION[PlayerSettings.aircraft_speed_units]) + PlayerSettings.aircraft_speed_units
		$Nav/GSReadout.text = \"%.1f \" %  (linked_object.unit.speed / Global.SPEED_CONVERSION[PlayerSettings.aircraft_speed_units]) + PlayerSettings.aircraft_speed_units
		$Nav/VSReadout.text = \"%.0f \" %  (linked_object.velocity.y / Global.SPEED_CONVERSION[PlayerSettings.vertical_speed_units]) + PlayerSettings.vertical_speed_units
		$Nav/MSLReadout.text = \"%.0f \" % (linked_object.unit.height / Global.DISTANCE_CONVERSION[PlayerSettings.altitude_units]) + PlayerSettings.altitude_units
		$Nav/AGLReadout.text = \"%.0f \" % ((linked_object.unit.height - max(linked_object.pos_data['height'], 0)) / Global.DISTANCE_CONVERSION[PlayerSettings.altitude_units]) + PlayerSettings.altitude_units
	elif taxi_mover.active:
		$Nav/HeadingReadout.text = \"%03.0f °\" % fposmod(taxi_mover.unit.global_rotation_degrees, 360)
		$Nav/TrackReadout.text = \"%03.0f °\" % fposmod(taxi_mover.unit.global_rotation_degrees, 360)
		$Nav/PitchReadout.text = \"0.0 °\"
		$Nav/TASReadout.text = \"%.1f \" % (taxi_mover.air_speed / Global.SPEED_CONVERSION[PlayerSettings.aircraft_speed_units]) + PlayerSettings.aircraft_speed_units
		$Nav/GSReadout.text = \"%.1f \" %  (taxi_mover.ground_speed / Global.SPEED_CONVERSION[PlayerSettings.aircraft_speed_units]) + PlayerSettings.aircraft_speed_units
		$Nav/VSReadout.text = \"0 \" + PlayerSettings.vertical_speed_units
		$Nav/MSLReadout.text = \"%.0f \" % (taxi_mover.unit.height / Global.DISTANCE_CONVERSION[PlayerSettings.altitude_units]) + PlayerSettings.altitude_units
		$Nav/AGLReadout.text = \"0 \" + PlayerSettings.altitude_units
	
	$Engine/PowerReadout.text = \"%.0f %%\" % (engine.power_setting * 100)
	$Engine/FuelReadout.text = \"%.0f \" % (engine.fuel / Global.VOLUME_CONVERSION[PlayerSettings.volume_units]) + PlayerSettings.volume_units
	
"

