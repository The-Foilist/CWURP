[sub_resource type="GDScript" id="GDScript_6k7pi"]
script/source = "extends TabContainer


func _unhandled_input(event):
	if event.is_action_pressed(\"tab_units\"):
		current_tab = 0
	if event.is_action_pressed(\"tab_selection\"):
		current_tab = 1
	if event.is_action_pressed(\"tab_map\"):
		current_tab = 2
"

[sub_resource type="GDScript" id="GDScript_texa1"]
script/source = "extends TextureRect


func _process(_delta):
	offset_transform_rotation = -Global.local_controller.cam.rotation


func _on_gui_input(event):
	if event is InputEventMouseButton:
		if event.button_index == MOUSE_BUTTON_LEFT:
			if event.pressed:
				Global.local_controller.cam.rotation = 0
"

[sub_resource type="GDScript" id="GDScript_qfoon"]
script/source = "extends Label


func _process(_delta) -> void:
	if Global.world:
		text = Global.world.time_str
"

[sub_resource type="GDScript" id="GDScript_0l2vu"]
script/source = "extends Label


func _process(_delta) -> void:
	if Global.world:
		text = \"×\" + str(Global.world.time_scale)
"

[sub_resource type="GDScript" id="GDScript_bmslg"]
script/source = "extends Label


func _process(_delta) -> void:
	if Global.world:
		visible = Global.world.pause
"

[sub_resource type="GDScript" id="GDScript_fv76v"]
script/source = "extends Button


func _pressed():
	Global.world.change_time_scale(0.5)


func _unhandled_input(event):
	if event.is_action_pressed(\"interface_slow_time\"):
		_pressed()
"

[sub_resource type="GDScript" id="GDScript_ok2yh"]
script/source = "extends Button


func _toggled(toggled_on):
	Global.world.toggle_pause(toggled_on)


func _unhandled_input(event):
	if event.is_action_pressed(\"interface_pause\"):
		button_pressed = !Global.world.pause
"

[sub_resource type="GDScript" id="GDScript_n0yxd"]
script/source = "extends Button


func _pressed():
	Global.world.change_time_scale(2)


func _unhandled_input(event):
	if event.is_action_pressed(\"interface_speed_time\"):
		_pressed()
"

