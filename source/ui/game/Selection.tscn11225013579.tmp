[gd_scene format=3 uid="uid://cgn3nu2ch7e0y"]

[sub_resource type="GDScript" id="GDScript_gabmv"]
script/source = "extends VBoxContainer


var connected_object: Unit


func clear() -> void:
	connected_object = null
	$HBoxContainer/Name.text = ''
	$HBoxContainer/Owner.text = ''
	for child in $ScrollContainer/InspectorsGoHere.get_children():
		$ScrollContainer/InspectorsGoHere.remove_child(child)
		child.queue_free()


func _on_object_selected(object: Unit) -> void:
	clear()
	if !object:
		return
	connected_object = object
	$HBoxContainer/Name.text = connected_object.display_name
	$HBoxContainer/Owner.text = connected_object.owning_player.name
	$HBoxContainer/Owner.add_theme_color_override(\"font_color\", connected_object.owning_player.color)
	
	var coords = connected_object.world.get_coords_at_position(connected_object.global_position)
	$Coords/LatReadout.text = \"%03.0f °\" % coords.x
	$Coords/LonReadout.text = \"%03.0f °\" % coords.y
	
	for child in connected_object.get_children():
		if child is Mover:
			if child.inspector:
				var new_inspector = child.inspector.instantiate()
				new_inspector.linked_object = child
				$ScrollContainer/InspectorsGoHere.add_child(new_inspector)


func _process(_delta):
	if !connected_object:
		clear()
		return
	if connected_object.active_mover:
		var coords = connected_object.active_mover.pos_data['coords']
		var minutes = Vector2(fmod(coords.x, 1), fmod(coords.y, 1)) * 60
		var seconds = Vector2(fmod(minutes.x, 1), fmod(minutes.y, 1)) * 60
		$Coords/LatReadout.text = \"%3.0f ° %2.0f \\' %2.0f \\\"\" % [coords.x, minutes.x, seconds.x]
		$Coords/LonReadout.text = \"%3.0f ° %2.0f \\' %2.0f \\\"\"% [coords.y, minutes.y, seconds.y]
"

