[sub_resource type="GDScript" id="GDScript_mrvir"]
script/source = "extends SubViewport


func _ready() -> void:
	world_2d = get_tree().current_scene.get_viewport().world_2d
"

[sub_resource type="GDScript" id="GDScript_0cjw3"]
script/source = "extends Label

@export var local_controller: LocalController

func _process(_delta) -> void:
	if local_controller.hovered_object:
		text = local_controller.hovered_object.display_name
	else:
		text = str(Global.world.get_coords_at_position(local_controller.mouse_coords))
"

